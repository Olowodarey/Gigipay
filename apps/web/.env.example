# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# WalletConnect Project ID — get from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Privy App ID — get from https://privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# Contract addresses (update after each deployment)
NEXT_PUBLIC_CONTRACT_ADDRESS_CELO=0x70b92a67F391F674aFFfCE3Dd7EB3d99e1f1E9a8
NEXT_PUBLIC_CONTRACT_ADDRESS_BASE=0xEdc6abb2f1A25A191dAf8B648c1A3686EfFE6Dd6

# Admin wallet addresses (comma-separated) — controls access to /admin/bills
# Leave empty to allow all connected wallets (dev only)
NEXT_PUBLIC_ADMIN_ADDRESSES=

# App public URL — used by Farcaster manifest and OG tags
NEXT_PUBLIC_URL=https://gigipay-app.vercel.app
